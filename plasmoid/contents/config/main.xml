<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0 http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
	<kcfgfile name=""/>
	<group name="General">
		<entry name="showBTC" type="Bool">
			<default>true</default>
		</entry>
		<entry name="showBTCTT" type="Bool">
			<default>true</default>
		</entry>
		<entry name="showBTCFee" type="Bool">
			<default>false</default>
		</entry>
		<entry name="showBTCFeeTT" type="Bool">
			<default>true</default>
		</entry>
		<entry name="showMetals" type="Bool">
			<default>false</default>
		</entry>
		<entry name="showMetalsRatio" type="Bool">
			<default>false</default>
		</entry>
		<entry name="showMetalsTT" type="Bool">
			<default>true</default>
		</entry>
		<entry name="showStack" type="Bool">
			<default>false</default>
		</entry>
	</group>
	<group name="Appearance">
		<entry name="appletColor" type="Bool">
			<default>true</default>
		</entry>
		<entry name="appletSymbol" type="String">
			<default>💰</default>
			<alt>🪙</alt>
			<alt>💲</alt>
		</entry>
		<entry name="stackSymbol" type="String">
			<default>∑</default>
		</entry>
		<entry name="curSymbol" type="String">
			<default>$</default>
		</entry>
		<entry name="minorcurSymbol" type="String">
			<default>¢</default>
		</entry>
		<entry name="btcSymbol" type="String">
			<default>₿</default>
			<alt>Ⓑ</alt>
		</entry>
		<entry name="satsSymbol" type="String">
			<default>Ș</default>
			<alt>≐</alt>
		</entry>
		<entry name="auSymbol" type="String">
			<default>Au</default>
			<alt>☀</alt>
			<alt>🥇</alt>
			<alt>🜚</alt>
		</entry>
		<entry name="agSymbol" type="String">
			<default>Ag</default>
			<alt>☾</alt>
			<alt>🥈</alt>
			<alt>🜛</alt>
		</entry>
		<entry name="warnSymbol" type="String">
			<default>⚠</default>
			<alt>☝</alt>
			<alt>!</alt>
		</entry>
		<entry name="delimSymbol" type="String">
			<default>│</default>
			<alt>·</alt>
			<alt>!</alt>
		</entry>
		<entry name="decPlaces" type="Int">
			<default>1</default>
		</entry>
		<entry name="decPlacesTT" type="Int">
			<default>2</default>
		</entry>
		<entry name="priceDivider" type="Int">
			<default>1000</default>
		</entry>
	</group>
	<group name="Fetch">
		<entry name="timeRefresh" type="Int">
			<default>30</default>
		</entry>
		<entry name="timeDataReady" type="Int">
			<default>10</default>
		</entry>
		<entry name="timeRefetch" type="Int">
			<default>15</default>
		</entry>
		<entry name="btcUrl" type="String">
			<default>https://api.gemini.com/v1/pubticker/btcusd</default>
		</entry>
		<entry name="btcKey" type="String">
			<default>last</default>
		</entry>
		<entry name="btcfeeUrl" type="String">
			<default>https://mempool.space/api/v1/fees/precise</default>
		</entry>
		<entry name="btcfeeKey" type="String">
			<default>economyFee</default>
			<options>fastestFee,halfHourFee,hourFee,economyFee,minimumFee</options>
		</entry>
		<entry name="metalsUrl" type="String">
			<default>https://api.gold-api.com/price/</default>
		</entry>
		<entry name="metalsSuffAu" type="String">
			<default>XAU</default>
		</entry>
		<entry name="metalsSuffAg" type="String">
			<default>XAG</default>
		</entry>
		<entry name="metalsKeyAu" type="String">
			<default>price</default>
		</entry>
		<entry name="metalsKeyAg" type="String">
			<default>price</default>
		</entry>
	</group>
	<group name="Stack">
		<entry name="btcStack" type="String">
			<default>1.234567</default>
		</entry>
		<entry name="btcCost" type="String">
			<default>100000.123456</default>
		</entry>
		<entry name="capGainBTC" type="Int">
			<default>15</default>
		</entry>
		<entry name="auStack" type="Int">
			<default>2</default>
		</entry>
		<entry name="auSlip" type="Int">
			<default>4</default>
		</entry>
		<entry name="agStack" type="Int">
			<default>3</default>
		</entry>
		<entry name="agSlip" type="Int">
			<default>8</default>
		</entry>
	</group>
</kcfg>
